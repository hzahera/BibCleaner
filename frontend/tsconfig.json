{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "strict": true,
        "noEmit": true,
        "types": [
            "vitest/globals",
            "node"
        ],
        "jsx": "preserve",
        "skipLibCheck": true
    },
    "include": [
        "src",
        "vite.config.ts",
        "vitest.config.ts"
    ]
}